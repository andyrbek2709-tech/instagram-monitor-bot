# ============================================================
# Instagram Monitor Bot — переменные окружения
# Установить в Railway: Settings → Variables
# ============================================================

# --- ОБЯЗАТЕЛЬНЫЕ ---

# Telegram Bot Token (получить у @BotFather)
TELEGRAM_BOT_TOKEN=

# HikerAPI ключ (зарегистрироваться на hikerapi.com)
# Заменяет прямой логин в Instagram — парсинг через API без сессий
HIKER_API_KEY=

# PostgreSQL URL (Railway выдаёт автоматически при добавлении Postgres)
DATABASE_URL=

# --- ОПЦИОНАЛЬНЫЕ (анализ деградирует без них, но бот запустится) ---

# Anthropic Claude API (для анализа постов через ИИ)
# Получить: https://console.anthropic.com/account/keys
CLAUDE_API_KEY=

# OpenAI API (для GPT-классификации контента: реклама/личное/приветствие)
# Получить: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- УСТАРЕВШИЕ (больше не нужны, можно не указывать) ---
# INSTAGRAM_USERNAME — HikerAPI не требует логина
# INSTAGRAM_PASSWORD — то же самое
