# ==================== КОНФИГУРАЦИЯ TELEGRAM ====================
# TELEGRAM_BOT_TOKEN - Токен бота от BotFather
# Как получить:
#   1. Напишите @BotFather в Telegram
#   2. /start → /newbot
#   3. Введите имя бота и юзернейм
#   4. BotFather отправит токен вида: 123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# TELEGRAM_CHAT_ID - ID вашего чата/пользователя (ОБЯЗАТЕЛЕН для отправки сообщений)
# Как получить:
#   1. Добавьте бота в группу или напишите ему в личку
#   2. Выполните: curl https://api.telegram.org/bot{ВАШ_ТОКЕН}/getUpdates
#   3. В ответе найдите "chat":{"id":12345678} или "from":{"id":12345678}
#   4. Скопируйте число - это ваш TELEGRAM_CHAT_ID
TELEGRAM_CHAT_ID=12345678

# ==================== API КЛЮЧИ ====================
# OPENAI_API_KEY - API ключ от OpenAI для GPT-4o-mini
# Получить: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# CLAUDE_API_KEY - API ключ от Anthropic для Claude
# Получить: https://console.anthropic.com/account/keys
CLAUDE_API_KEY=sk-ant-v4-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==================== УЧЕТНЫЕ ДАННЫЕ INSTAGRAM ====================
# Instagram аккаунт для мониторинга
# ВАЖНО: Используйте вспомогательный аккаунт, не основной!
INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password

# ==================== КОНФИГУРАЦИЯ БД ====================
# Путь к SQLite базе данных
# На Railway используйте /app/data/instagram_monitor.db (Volume mount path)
DATABASE_PATH=/app/data/instagram_monitor.db

# ==================== КОНФИГУРАЦИЯ БОТА ====================
# Временная зона для расписания дайджестов
TIMEZONE=Europe/Moscow

# Время отправки ежедневного дайджеста (HH:MM)
DAILY_DIGEST_TIME=09:00

# Интервал проверки новых постов (в минутах)
CHECK_INTERVAL_MINUTES=60

# Минимальный порог релевантности для уведомлений
MIN_RELEVANCE_THRESHOLD=0.5

# ==================== АНТИДЕТЕКЦИЯ (Anti-Detection) ====================
# Минимальная задержка между постами (сек)
MIN_REQUEST_DELAY=8

# Максимальная задержка между постами (сек)
MAX_REQUEST_DELAY=20

# Минимальная задержка между аккаунтами (сек)
MIN_ACCOUNT_DELAY=30

# Максимальная задержка между аккаунтами (сек)
MAX_ACCOUNT_DELAY=90

# Использовать прокси для Instagram
USE_PROXY=false

# ==================== ОПЦИОНАЛЬНО ====================
# URL прокси (если USE_PROXY=true)
PROXY_URL=

# Уровень логирования (DEBUG/INFO/WARNING/ERROR)
LOG_LEVEL=INFO

# Путь для логов
LOG_FILE=/app/logs/bot.log
