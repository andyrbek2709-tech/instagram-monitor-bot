# Instagram Monitor Bot Configuration
# Copy this file to .env and fill in your actual values

# TELEGRAM BOT TOKEN
# Get from Telegram BotFather (@BotFather on Telegram)
# 1. Open Telegram and search for @BotFather
# 2. Send /newbot command and follow instructions
# 3. Copy the token provided
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# OPENAI API KEY
# Get from OpenAI API Dashboard (https://platform.openai.com/api-keys)
# 1. Log in to your OpenAI account
# 2. Go to API Keys section
# 3. Create new secret key
# 4. Copy the key (shown only once)
OPENAI_API_KEY=your_openai_api_key_here

# CLAUDE API KEY (Anthropic)
# Get from Anthropic Console (https://console.anthropic.com)
# 1. Log in to your Anthropic account
# 2. Go to API Keys section
# 3. Create new API key
# 4. Copy the key
CLAUDE_API_KEY=your_claude_api_key_here

# INSTAGRAM CREDENTIALS
# Your Instagram account username and password for scraping
INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password

# DATABASE CONFIGURATION
DATABASE_PATH=./data/instagram_monitor.db
DATABASE_BACKUP_PATH=./data/backups

# LOGGING CONFIGURATION
LOG_LEVEL=INFO
LOG_FILE=./logs/bot.log

# BOT BEHAVIOR CONFIGURATION
POLL_INTERVAL=300
MAX_POSTS_PER_POLL=10
SENTIMENT_THRESHOLD=0.5

# TELEGRAM NOTIFICATION SETTINGS
NOTIFY_ON_NEW_POSTS=true
NOTIFY_ON_HIGH_ENGAGEMENT=true
NOTIFY_ON_SENTIMENT_ALERTS=true
