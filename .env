# ========== INSTAGRAM CREDENTIALS ==========
# Основной аккаунт для входа
INSTAGRAM_USERNAME=andreyfuture27
INSTAGRAM_PASSWORD=Andreyka@2709

# ========== DATABASE CONFIGURATION ==========
# Путь к SQLite базе данных
DATABASE_PATH=./database/instagram_monitor.db

# ========== BOT CONFIGURATION ==========
# Часовой пояс для расписания (IANA format)
# Доступные значения: Europe/Moscow, Europe/London, America/New_York и т.д.
TIMEZONE=Europe/Moscow

# Базовое время для ежедневной рассылки (формат HH:MM)
# Система добавит случайное отклонение ±15 минут
DAILY_DIGEST_TIME=09:00

# Интервал проверки новых постов (в минутах)
CHECK_INTERVAL_MINUTES=60

# ========== LOGGING CONFIGURATION ==========
# Уровень логирования: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ========== ANTI-DETECTION STRATEGY ==========
# Минимальная задержка между запросами к Instagram (секунды)
MIN_REQUEST_DELAY=8

# Максимальная задержка между запросами к Instagram (секунды)
MAX_REQUEST_DELAY=20

# Минимальная задержка между переключением аккаунтов (секунды)
MIN_ACCOUNT_DELAY=30

# Максимальная задержка между переключением аккаунтов (секунды)
MAX_ACCOUNT_DELAY=90

# ========== ANALYSIS CONFIGURATION ==========
# Минимальный порог релевантности (0.0 - 1.0)
# Посты с релевантностью ниже этого значения не будут отправлены
MIN_RELEVANCE_THRESHOLD=0.5

# Включить анализ изображений (требует GPT-4o Vision)
ENABLE_VISION_ANALYSIS=false

# ========== SESSION MANAGEMENT ==========
# Сохранять ли сессии Instagram для более быстрого входа
PERSIST_SESSIONS=true

# Директория для сохранения сессий
SESSIONS_DIR=./data/sessions

# Директория для сохранения медиа файлов
MEDIA_DIR=./data/media

# ========== OPTIONAL: PROXY CONFIGURATION ==========
# Для дополнительной скрытности можно использовать прокси
# PROXY_URL=http://proxy_ip:proxy_port
# PROXY_USERNAME=proxy_user
# PROXY_PASSWORD=proxy_pass