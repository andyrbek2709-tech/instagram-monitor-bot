# .env - Configuration Template
# This file is ignored by Git (.gitignore)
# Create a copy with actual values for local development
# For production, set environment variables directly in the deployment platform

# TELEGRAM CONFIGURATION
TELEGRAM_CHAT_ID=
TELEGRAM_BOT_TOKEN=

# API KEYS
OPENAI_API_KEY=
CLAUDE_API_KEY=

# INSTAGRAM CREDENTIALS
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=

# DATABASE
DATABASE_PATH=./database/instagram_monitor.db

# BOT CONFIGURATION
TIMEZONE=Europe/Moscow
DAILY_DIGEST_TIME=09:00
CHECK_INTERVAL_MINUTES=60
LOG_LEVEL=INFO

# ANTI-DETECTION
MIN_REQUEST_DELAY=8
MAX_REQUEST_DELAY=20
MIN_ACCOUNT_DELAY=30
MAX_ACCOUNT_DELAY=90

# ANALYSIS
MIN_RELEVANCE_THRESHOLD=0.5
ENABLE_VISION_ANALYSIS=false

# SESSIONS
PERSIST_SESSIONS=true
SESSIONS_DIR=./data/sessions
MEDIA_DIR=./data/media
