# Production Environment Configuration
# For use in deployed environments (VPS, Docker, etc.)

# Telegram Bot Token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Claude API Key
CLAUDE_API_KEY=your_anthropic_api_key_here

# Instagram Credentials
INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password

# Database Configuration
DATABASE_PATH=/app/data/monitor.db
DATABASE_BACKUP_PATH=/app/data/backups

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=/app/logs/bot.log

# Bot Behavior Configuration
POLL_INTERVAL=300
MAX_POSTS_PER_POLL=10
SENTIMENT_THRESHOLD=0.7

# Notification Settings
NOTIFY_ON_NEW_POSTS=true
NOTIFY_ON_HIGH_ENGAGEMENT=true
NOTIFY_ON_SENTIMENT_ALERTS=true
